# ========================================
# Environment Configuration for Chunav Mitra Frontend
# ========================================
# Copy this file to .env and update values as needed
# cp .env.example .env
# ========================================

# ----------------------------------------
# API Configuration
# ----------------------------------------
# Production: https://chunav-mitra-av4k.onrender.com
# Development: http://localhost:8000

# Default to production - no need to change for deployed app
VITE_API_BASE_URL=https://chunav-mitra-av4k.onrender.com

# Uncomment below for local development
# VITE_API_BASE_URL=http://localhost:8000

# ----------------------------------------
# Google Maps (Optional)
# ----------------------------------------
# Not required - app uses OpenStreetMap for booth locator
VITE_GOOGLE_MAPS_KEY=optional_not_required

# ----------------------------------------
# Environment Switching Guide
# ----------------------------------------
# For DEVELOPMENT (local backend):
#   1. VITE_API_BASE_URL=http://localhost:8000
#   2. npm run dev
#
# For PRODUCTION (deployed backend):
#   1. VITE_API_BASE_URL=https://chunav-mitra-av4k.onrender.com
#   2. npm run build
#   3. npm run preview (to test locally)
#
# For BUILD/Deploy:
#   - Use production URL before building
#   - Vite will bundle the correct URL at build time
